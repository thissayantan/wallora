<?xml version="1.0" encoding="utf-8"?>
<!--
  "Next wallpaper" icon for the QS tile and app shortcut.
  24×24dp, single colour (#FFFFFF) so the OS/QS panel tints it freely.

  Design: the Wallora card silhouette (left) + skip-forward arrow (right).
  The card is a proportionally correct mini version of the logo's front card.
  The arrow is a filled right-pointing skip symbol (bar + chevron).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Card silhouette: mini Wallora card, left-aligned -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M4,2.5 L12,2.5 Q14,2.5 14,4.5 L14,19.5 Q14,21.5 12,21.5 L4,21.5 Q2,21.5 2,19.5 L2,4.5 Q2,2.5 4,2.5 Z" />

    <!-- Skip-forward arrow: vertical bar + filled right-pointing chevron -->
    <!-- Bar -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M16,8 L17.5,8 L17.5,16 L16,16 Z" />
    <!-- Chevron -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M17.5,8 L17.5,16 L22.5,12 Z" />

</vector>
