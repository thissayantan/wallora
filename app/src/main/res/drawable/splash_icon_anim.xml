<?xml version="1.0" encoding="utf-8"?>
<!--
  Splash screen animated icon.
  Plays a subtle scale-up (0.88 → 1.0) + fade-in (0 → 1) on the icon group
  for ~400 ms. The splash background is dark (#0E0E11 via themes.xml).
  No artificial delay is added to the splash — the animation runs only during
  the natural window-setup time before the first Compose frame is ready.
-->
<animated-vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:drawable="@drawable/ic_launcher_foreground">

    <target android:name="icon_root">
        <aapt:attr name="android:animation">
            <set xmlns:android="http://schemas.android.com/apk/res/android"
                android:ordering="together">
                <!-- Fade in: 0 → 1 -->
                <objectAnimator
                    android:propertyName="alpha"
                    android:valueType="floatType"
                    android:valueFrom="0.0"
                    android:valueTo="1.0"
                    android:duration="400"
                    android:interpolator="@android:interpolator/decelerate_quint" />
                <!-- Scale up from 88% → 100% (uniform, pivotX/Y=54 set on the group) -->
                <objectAnimator
                    android:propertyName="scaleX"
                    android:valueType="floatType"
                    android:valueFrom="0.88"
                    android:valueTo="1.0"
                    android:duration="400"
                    android:interpolator="@android:interpolator/decelerate_quint" />
                <objectAnimator
                    android:propertyName="scaleY"
                    android:valueType="floatType"
                    android:valueFrom="0.88"
                    android:valueTo="1.0"
                    android:duration="400"
                    android:interpolator="@android:interpolator/decelerate_quint" />
            </set>
        </aapt:attr>
    </target>

</animated-vector>
