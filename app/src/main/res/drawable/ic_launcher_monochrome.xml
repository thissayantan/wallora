<?xml version="1.0" encoding="utf-8"?>
<!-- Monochrome layer for Android 13+ themed icon support.
     Even-odd fill punches the frame interior transparent so the OS accent
     tints only the ring, mountains, and sun. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Frame ring: outer rounded rect minus inner cutout (evenOdd rule) -->
    <path
        android:fillColor="#FFFFFF"
        android:fillType="evenOdd"
        android:pathData="M30,28 L78,28 Q88,28 88,38 L88,72 Q88,82 78,82 L30,82 Q20,82 20,72 L20,38 Q20,28 30,28 Z M30,33 L78,33 Q83,33 83,38 L83,63 Q83,68 78,68 L30,68 Q25,68 25,63 L25,38 Q25,33 30,33 Z" />

    <!-- Mountain silhouette -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M22,70 L41,52 L54,61 L67,46 L86,70 Z" />

    <!-- Sun disc -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M76,43 m-5,0 a5,5 0 1,0 10,0 a5,5 0 1,0 -10,0" />

</vector>
